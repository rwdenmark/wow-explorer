# Normalize line endings: store text as LF in the repo, check out native on disk.
* text=auto eol=lf

# Explicitly mark common text formats (LF in repo).
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sql    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.env    text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Binary files: never modify.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.jar    binary
*.war    binary
